<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ════════════════════════════════════════════════════════════════
         Vista del wizard de filtros para el Balance de Situación
         ════════════════════════════════════════════════════════════════ -->
    <record id="view_balance_situacion_wizard_form" model="ir.ui.view">
        <field name="name">balance.situacion.wizard.form</field>
        <field name="model">balance.situacion.wizard</field>
        <field name="arch" type="xml">
            <form string="Balance de Situación">
                <group string="Parámetros del reporte">
                    <group>
                        <field name="company_id" options="{'no_create': True}"/>
                        <field name="date_from"/>
                        <field name="date_to" required="1"/>
                    </group>
                    <group>
                        <field name="only_posted"/>
                        <field name="accrual_basis"/>
                    </group>
                </group>
                <group string="Filtros opcionales">
                    <field name="journal_ids" widget="many2many_tags"
                           placeholder="Todos los diarios"/>
                </group>
                <footer>
                    <button name="action_generate_report"
                            string="Generar PDF"
                            type="object"
                            class="btn-primary"
                            icon="fa-print"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Acción que abre el wizard -->
    <record id="action_balance_situacion_wizard" model="ir.actions.act_window">
        <field name="name">Balance de Situación</field>
        <field name="res_model">balance.situacion.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
