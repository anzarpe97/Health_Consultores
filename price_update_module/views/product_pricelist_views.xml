<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="view_product_pricelist_form_price_update" model="ir.ui.view">
        <field name="name">product.pricelist.form.price.update</field>
        <field name="model">product.pricelist</field>
        <field name="priority" eval="99" />
        <field name="inherit_id" ref="product.product_pricelist_view" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='currency_id']" position="after">
                <field name="rate" readonly="1" />
            </xpath>
            <xpath expr="//page[@name='pricelist_rules']/field[@name='item_ids']/tree/field[@name='fixed_price']" position="before">
                <field name="price_usd" optional="show" />
            </xpath>
        </field>
    </record>

    <record id="view_product_pricelist_item_form_price_update" model="ir.ui.view">
        <field name="name">product.pricelist.item.form.price.update</field>
        <field name="model">product.pricelist.item</field>
        <field name="priority" eval="99" />
        <field name="inherit_id" ref="product.product_pricelist_item_form_view" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='fixed_price']" position="before">
                <field name="price_usd" />
            </xpath>
        </field>
    </record>
</odoo>
