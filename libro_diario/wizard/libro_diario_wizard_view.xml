<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_libro_diario_wizard_form" model="ir.ui.view">
        <field name="name">libro.diario.wizard.form</field>
        <field name="model">libro.diario.wizard</field>
        <field name="arch" type="xml">
            <form string="Diario Legal">
                <group>
                    <group>
                        <field name="date_from"/>
                        <field name="date_to"/>
                    </group>
                    <group>
                        <field name="company_id" groups="base.group_multi_company"/>
                    </group>
                </group>
                <footer>
                    <button name="print_report" string="Imprimir" type="object" class="btn-primary"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_libro_diario_wizard" model="ir.actions.act_window">
        <field name="name">Diario Legal</field>
        <field name="res_model">libro.diario.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_libro_diario_wizard"
              name="Imprimir Diario Legal"
              action="action_libro_diario_wizard"
              parent="account.menu_finance_reports"
              sequence="20"/>
</odoo>
