<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- ============================================================ -->
        <!-- CUSTOM TRIAL BALANCE REPORT (LIBRO DIARIO)                   -->
        <!-- Lines generated by CustomTrialBalanceHandler (_get_lines)    -->
        <!-- ============================================================ -->

        <record id="custom_trial_balance_report_ld" model="account.report">
            <field name="name">Libro Diario</field>
            <field name="filter_date_range" eval="True"/>
            <field name="filter_journals" eval="True"/>
            <field name="filter_unfold_all" eval="True"/>
            <field name="load_more_limit">80</field>
            <field name="search_bar" eval="True"/>
            <field name="custom_handler_model_id" ref="model_custom_trial_balance_handler"/>
        </record>

        <!-- Columns only - lines are generated by Python -->
        <record id="custom_trial_balance_column_debit_ld" model="account.report.column">
            <field name="name">Debe</field>
            <field name="expression_label">debit</field>
            <field name="figure_type">monetary</field>
            <field name="report_id" ref="custom_trial_balance_report_ld"/>
            <field name="sequence">1</field>
        </record>

        <record id="custom_trial_balance_column_credit_ld" model="account.report.column">
            <field name="name">Haber</field>
            <field name="expression_label">credit</field>
            <field name="figure_type">monetary</field>
            <field name="report_id" ref="custom_trial_balance_report_ld"/>
            <field name="sequence">2</field>
        </record>

        <!-- Action and Menu -->
        <record id="action_custom_trial_balance_report_ld" model="ir.actions.client">
            <field name="name">Libro Diario</field>
            <field name="tag">account_report</field>
            <field name="context" eval="{'report_id': ref('custom_trial_balance_report_ld')}"/>
        </record>

        <menuitem id="menu_custom_trial_balance_ld"
                  name="Libro Diario"
                  action="action_custom_trial_balance_report_ld"
                  parent="account.menu_finance_reports"
                  sequence="12"/>
    </data>
</odoo>
