<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="custom_external_layout_standard" inherit_id="web.external_layout_standard">
        
        <xpath expr="//div[@name='moto']" position="replace">
            <div class="col-9 text-end" style="margin-top:40px;">
                <span style="color: #875A7B; font-weight: bold;">¡Texto personalizado para todos los reportes!</span>
            </div>
        </xpath>

        <xpath expr="//div[@name='company_address']" position="inside">
            <div class="mt-2 text-muted">
                <small>Horario de atención: Lunes a Viernes 9:00 - 18:00</small>
            </div>
        </xpath>

        <xpath expr="//div[@class='row zero_min_height']//div[@style='border-bottom: 1px solid black;']" position="attributes">
            <attribute name="style">border-bottom: 2px solid #0055ff;</attribute>
        </xpath>

    </template>
</odoo>