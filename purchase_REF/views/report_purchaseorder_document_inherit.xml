<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_purchaseorder_document_inherit_usd" inherit_id="purchase.report_purchaseorder_document">
        
        <!-- Change Title to "Orden de Servicio" -->
        <xpath expr="//h2[@t-if=&quot;o.state in ['draft', 'sent', 'to approve']&quot;]" position="replace">
            <h2 t-if="o.state in ['draft', 'sent', 'to approve']">Solicitud de Servicio #<span t-field="o.name"/></h2>
        </xpath>
        <xpath expr="//h2[@t-if=&quot;o.state in ['purchase', 'done']&quot;]" position="replace">
            <h2 t-if="o.state in ['purchase', 'done']">Orden de Servicio #<span t-field="o.name"/></h2>
        </xpath>
        <xpath expr="//h2[@t-if=&quot;o.state == 'cancel'&quot;]" position="replace">
            <h2 t-if="o.state == 'cancel'">Orden de Servicio Cancelada #<span t-field="o.name"/></h2>
        </xpath>

        <!-- Variable to set USD rate -->
        <xpath expr="//div[@class='page']" position="before">
            <t t-set="usd_currency" t-value="o.env.ref('base.USD')"/>
            <t t-set="is_usd" t-value="o.currency_id == usd_currency"/>
            <t t-set="order_rate" t-value="1.0 if is_usd else o.currency_id._get_conversion_rate(o.currency_id, usd_currency, o.company_id, o.date_order or datetime.datetime.now())"/>
        </xpath>

        <!-- Replace unit price -->
        <xpath expr="//td/span[@t-field='line.price_unit']" position="replace">
            <t t-set="usd_price" t-value="line.price_unit if is_usd else line.ref_unit"/>
            <span t-esc="usd_price" t-options='{"widget": "monetary", "display_currency": usd_currency}'/>
        </xpath>

        <!-- Replace subtotal in lines -->
        <xpath expr="//td/span[@t-field='line.price_subtotal']" position="replace">
            <t t-set="usd_subtotal" t-value="line.price_subtotal if is_usd else line.ref"/>
            <span t-esc="usd_subtotal" t-options='{"widget": "monetary", "display_currency": usd_currency}'/>
        </xpath>

        <!-- Replace subtotal in sections -->
        <xpath expr="//tr[@class='is-subtotal text-end']//span[@t-esc='current_subtotal']" position="replace">
            <t t-set="current_subtotal_usd" t-value="current_subtotal * order_rate"/>
            <span t-esc="current_subtotal_usd" t-options='{"widget": "monetary", "display_currency": usd_currency}'/>
        </xpath>

        <!-- Replace entire Totals Table to show only USD -->
        <xpath expr="//div[@id='total']//table" position="replace">
            <table class="table table-sm table-borderless">
                <tr class="border-black o_subtotal">
                    <td><strong>Subtotal</strong></td>
                    <td class="text-right text-end">
                        <t t-set="amount_untaxed_usd" t-value="o.amount_untaxed * order_rate"/>
                        <span t-esc="amount_untaxed_usd" t-options='{"widget": "monetary", "display_currency": usd_currency}'/>
                    </td>
                </tr>
                <tr>
                    <td>Impuestos</td>
                    <td class="text-right text-end">
                        <t t-set="amount_tax_usd" t-value="o.amount_tax * order_rate"/>
                        <span t-esc="amount_tax_usd" t-options='{"widget": "monetary", "display_currency": usd_currency}'/>
                    </td>
                </tr>
                <tr class="border-black o_total">
                    <td><strong>Total</strong></td>
                    <td class="text-right text-end">
                        <t t-set="amount_total_usd" t-value="o.amount_total * order_rate"/>
                        <span t-esc="amount_total_usd" t-options='{"widget": "monetary", "display_currency": usd_currency}'/>
                    </td>
                </tr>
            </table>
        </xpath>

    </template>
</odoo>
