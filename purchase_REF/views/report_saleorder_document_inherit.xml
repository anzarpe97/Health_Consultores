<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_saleorder_document_inherit_usd" inherit_id="sale.report_saleorder_document">
        
        <!-- Cambiar Titulo a "Orden de Servicio" -->
        <xpath expr="//h2[@class='mt-4']" position="replace">
            <h2 class="mt-4">
                <span t-if="env.context.get('proforma', False) or is_pro_forma">Pro-Forma de Servicio # </span>
                <span t-elif="doc.state in ['draft','sent']">Solicitud de Servicio # </span>
                <span t-else="">Orden de Servicio # </span>
                <span t-field="doc.name">SO0000</span>
            </h2>
        </xpath>

        <!-- Variable de Tasa USD -->
        <xpath expr="//div[@class='page']" position="before">
            <t t-set="usd_currency" t-value="doc.env.ref('base.USD')"/>
            <t t-set="is_usd" t-value="doc.currency_id == usd_currency"/>
            <t t-set="order_rate" t-value="1.0 if is_usd else doc.currency_id._get_conversion_rate(doc.currency_id, usd_currency, doc.company_id, doc.date_order or datetime.datetime.now())"/>
        </xpath>

        <!-- Reemplazar Precio Unitario en lineas -->
        <xpath expr="//span[@t-field='line.price_unit']" position="replace">
            <t t-set="usd_price" t-value="line.price_unit * order_rate"/>
            <span t-esc="usd_price" t-options='{"widget": "monetary", "display_currency": usd_currency}'/>
        </xpath>

        <!-- Reemplazar Subtotal en lineas -->
        <xpath expr="//span[@t-field='line.price_subtotal']" position="replace">
            <t t-set="usd_subtotal" t-value="line.price_subtotal * order_rate"/>
            <span t-esc="usd_subtotal" t-options='{"widget": "monetary", "display_currency": usd_currency}'/>
        </xpath>

        <!-- Reemplazar Totales -->
        <xpath expr="//div[@id='total']//table" position="replace">
            <table class="table table-sm table-borderless">
                <tr class="border-black o_subtotal">
                    <td><strong>Subtotal</strong></td>
                    <td class="text-end">
                        <t t-set="amount_untaxed_usd" t-value="doc.amount_untaxed * order_rate"/>
                        <span t-esc="amount_untaxed_usd" t-options='{"widget": "monetary", "display_currency": usd_currency}'/>
                    </td>
                </tr>
                <tr>
                    <td>Impuestos</td>
                    <td class="text-end">
                        <t t-set="amount_tax_usd" t-value="doc.amount_tax * order_rate"/>
                        <span t-esc="amount_tax_usd" t-options='{"widget": "monetary", "display_currency": usd_currency}'/>
                    </td>
                </tr>
                <tr class="border-black o_total">
                    <td><strong>Total</strong></td>
                    <td class="text-end">
                        <t t-set="amount_total_usd" t-value="doc.amount_total * order_rate"/>
                        <span t-esc="amount_total_usd" t-options='{"widget": "monetary", "display_currency": usd_currency}'/>
                    </td>
                </tr>
            </table>
        </xpath>

    </template>
</odoo>
