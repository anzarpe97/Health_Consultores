<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="custom_financial_report_address_main" inherit_id="account_reports.pdf_export_main">
        <!-- Reemplazamos el título principal para inyectar nuestro cuadro con la información de la empresa -->
        <xpath expr="//h2 | //*[contains(@t-out, 'report_title')]/.." position="replace">
            <style>
                .o_account_reports_header > h2 { display: none !important; }
            </style>
            <div style="background-color: #f0f0f0 !important; -webkit-print-color-adjust: exact !important; print-color-adjust: exact !important; padding: 15px; margin-bottom: 20px; border-radius: 4px; border: 1px solid #dddddd; page-break-inside: avoid;">
                <h3 style="font-weight: bold; margin-bottom: 10px; font-size: 20px; color: #000; margin-top: 0;">
                    <t t-if="report.filter_show_draft and options.get('all_entries')">[Borrador] </t>
                    <t t-out="report_title"/>
                </h3>
                <div style="font-size: 13px; color: #000; line-height: 1.4;">
                    <div t-out="env.company.name" style="font-weight: bold;"/>
                    <t t-if="env.company.street"><div t-out="env.company.street"/></t>
                    <t t-if="env.company.street2"><div t-out="env.company.street2"/></t>
                    <div>
                        <t t-if="env.company.city"><span t-out="env.company.city"/> </t>
                        <t t-if="env.company.state_id"><span t-out="env.company.state_id.name"/> </t>
                        <t t-if="env.company.zip"><span t-out="env.company.zip"/></t>
                    </div>
                    <t t-if="env.company.country_id"><div t-out="env.company.country_id.name"/></t>
                    
                    <div t-if="env.company.vat" style="margin-top: 5px; font-weight: bold; background-color: #ffff00; display: inline-block; padding: 2px 5px;">
                        NIF: <t t-out="env.company.vat"/>
                    </div>
                    <div t-elif="env.company.company_registry" style="margin-top: 5px; font-weight: bold; background-color: #ffff00; display: inline-block; padding: 2px 5px;">
                        NIF: <t t-out="env.company.company_registry"/>
                    </div>
                </div>
            </div>
        </xpath>
    </template>
</odoo>
